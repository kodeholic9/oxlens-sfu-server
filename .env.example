# oxlens-sfu-server 환경 설정
# 이 파일을 .env 로 복사하여 사용
# 미설정 항목은 기본값으로 동작

# 클라이언트 ICE candidate에 노출할 공인 IP
# 미설정 시 라우팅 테이블 기반 자동 감지 (내부망 IP)
# LTE/외부 접속 시 반드시 공인 IP 설정 필요
# PUBLIC_IP=121.xxx.xxx.xxx

# WebSocket 시그널링 포트 (기본: 1974)
# WS_PORT=1974

# UDP 미디어 포트 (기본: 19740)
# UDP_PORT=19740

# 로그 디렉토리 (미설정 또는 디렉토리 없으면 콘솔 출력)
# 설정 시 일별 로테이션: oxsfud.log.YYYY-MM-DD
# LOG_DIR=/var/log/livechat

# 로그 레벨 (기본: info)
# RUST_LOG 환경변수가 있으면 그쪽이 우선
# LOG_LEVEL=info
